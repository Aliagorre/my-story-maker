{
  "nodes": [
    {"id": "start",
      "text": [
        {"value": "Une chance sur 2 (Normallement).",
         "conditions": { "chance" : 0.5}
        },
        {"value": "Vous vous réveillez dans une clairière.",
          "conditions": { "not" : "visited_clearing"}
        },
        {"value": "Vous êtes de retour dans la clairière.",
          "conditions": "visited_clearing"
        },
        {"value": "Vous êtes dans une clairière."
        }
      ],
      "on_quit": [
        { "set": ["visited_clearing", true],
          "conditions": { "not" : "visited_clearing"} 
        }
      ],
      "choices": [
        {"id": "look",
          "text": "Observer les environs",
          "goto": "look_around"
        },
        {"id": "take_sword",
          "text": "Ramasser l'épée",
          "goto": "take_sword",
          "conditions": { "not": "has_sword" }
        },
        {"id": "go_forest",
          "text": "Aller dans la forêt",
          "goto": "forest",
          "conditions": {
            "and": [
              { "not": "has_sword" },
              { "gt": ["player.strength", 4] }
            ]
          }
        }
      ]
    },

    {"id": "look_around",
      "text": "Vous voyez une épée rouillée et un chemin vers la forêt.",
      "choices": [
        { "id": "take_sword", "text": "Ramasser l'épée", "goto": "take_sword" }
      ]
    },

    {"id": "take_sword",
      "text": "Vous ramassez l'épée.",
      "on_enter": [
        { "set": ["has_sword", true] }
      ],
      "choices": [
        {"id": "go_forest",
          "text": "Aller dans la forêt",
          "goto": "forest",
          "conditions": {
            "and": [
              "has_sword",
              { "gt": ["player.strength", 4] }
            ]
          }
        }
      ]
    },

    {"id": "forest",
      "text": "La forêt est sombre. Un troll apparaît.",
      "choices": [
        { "id": "fight",
          "text": "Combattre le troll",
          "goto": "fight",
          "conditions": {
            "and": [
              "has_sword",
              { "gte": ["player.strength", 5] }
            ]
          }
        },
        { "id": "bribe",
          "text": "Payer le troll pour passer",
          "goto": "bribe",
          "conditions": {
            "gt": [12, 10]
          }
        },
        { "id": "run",
          "text": "Fuir",
          "goto": "start"
        }
      ]
    },

    { "id": "fight",
      "text": "Vous terrassez le troll !",
      "choices": [
        { "id": "loot", "text": "Fouiller le troll", "goto": "loot" }
      ]
    },

    { "id": "bribe",
      "text": "Le troll accepte votre or et vous laisse passer.",
      "choices": [
        { "id": "continue", "text": "Continuer", "goto": "deep_forest" }
      ]
    },

    {"id": "loot",
      "text": "Vous trouvez 20 pièces d'or.",
      "choices": [
        { "id": "continue", "text": "Continuer", "goto": "deep_forest" }
      ]
    },

    {"id": "deep_forest",
      "text": "Vous atteignez la forêt profonde. Une aura magique vous entoure.",
      "choices": [
        { "id": "secret",
          "text": "Entrer dans le sanctuaire secret",
          "goto": "secret",
          "conditions": {
            "eq": [
              { "gt": [12, 10] },
              true
            ]
          }
        },
        {
          "id": "end",
          "text": "Fin de la démo",
          "goto": "end"
        }
      ]
    },

    {"id": "secret",
      "text": "Le sanctuaire vous accueille. Vous êtes reconnu comme allié des mages.",
      "choices": [
        { "id": "end", "text": "Fin", "goto": "end" }
      ]
    },

    {"id": "end",
      "text": "Merci d'avoir joué à la démo !",
      "choices": []
    }
  ]
}